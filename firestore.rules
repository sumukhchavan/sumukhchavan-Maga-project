rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, role, displayName, email, photoURL, location, trade, skills, experience, wageExpectation, bio, dakshScore, isVerified, verifiedBadges, createdAt
    //
    // Collection: jobs
    // Fields: employerId, employerName, title, description, skillRequired, location, duration, wage, wageType, status, applicantsCount, createdAt
    //
    // Collection: reviews
    // Fields: workerId, employerId, employerName, rating, comment, createdAt
    //
    // Collection: applications
    // Fields: jobId, workerId, workerName, status, createdAt
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "sumukhchavan6@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'role', 'displayName', 'email']) &&
             data.uid is string &&
             data.role in ['worker', 'employer', 'admin'] &&
             data.displayName is string && data.displayName.size() < 100 &&
             data.email is string;
    }

    function isValidJob(data) {
      return data.keys().hasAll(['employerId', 'title', 'skillRequired', 'wage', 'status']) &&
             data.employerId is string &&
             data.title is string && data.title.size() < 200 &&
             data.wage is number && data.wage >= 0;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['workerId', 'employerId', 'rating']) &&
             data.workerId is string &&
             data.employerId is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5;
    }

    function isValidApplication(data) {
      return data.keys().hasAll(['jobId', 'workerId', 'status']) &&
             data.jobId is string &&
             data.workerId is string &&
             data.status in ['pending', 'hired', 'rejected'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() || resource.data.role == 'worker';
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /jobs/{jobId} {
      allow read: if true; // Publicly viewable job board
      allow create: if isAuthenticated() && isValidJob(request.resource.data) && request.resource.data.employerId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.employerId == request.auth.uid || isAdmin()) && isValidJob(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.employerId == request.auth.uid || isAdmin());
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidReview(request.resource.data) && request.resource.data.employerId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /applications/{applicationId} {
      allow read: if isAuthenticated() && (resource.data.workerId == request.auth.uid || get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.employerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidApplication(request.resource.data) && request.resource.data.workerId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.workerId == request.auth.uid || get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.employerId == request.auth.uid || isAdmin()) && isValidApplication(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.workerId == request.auth.uid || isAdmin());
    }
  }
}
